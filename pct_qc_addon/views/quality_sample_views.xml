<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sample List View -->
    <record id="quality_sample_view_tree" model="ir.ui.view">
        <field name="name">quality.sample.list</field>
        <field name="model">quality.sample</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Sample Form View -->
    <record id="quality_sample_view_form" model="ir.ui.view">
        <field name="name">quality.sample.form</field>
        <field name="model">quality.sample</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Sample Search View -->
    <record id="quality_sample_view_search" model="ir.ui.view">
        <field name="name">quality.sample.search</field>
        <field name="model">quality.sample</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
            </search>
        </field>
    </record>

    <!-- Sample Action -->
    <record id="quality_sample_action" model="ir.actions.act_window">
        <field name="name">Samples</field>
        <field name="res_model">quality.sample</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new sample
            </p>
        </field>
    </record>

    <!-- Sample Menu (under Quality > Configuration) -->
    <menuitem
        id="menu_quality_sample"
        name="Samples"
        action="quality_sample_action"
        parent="quality_control.menu_quality_configuration"
        sequence="45"/>

</odoo>
