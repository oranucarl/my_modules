<odoo>
    <template id="report_purchase_request">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div id="oe_structure_report_request_1" class="oe_structure" />
                        <h2>
                            Purchase Request
                            <span t-field="o.name" />
                        </h2>
                        <div class="row mt32 mb32">
                            <div class="col-2">
                                <strong>Request Reference:</strong>
                                <br />
                                <span t-field="o.name" />
                            </div>
                            <div class="col-2">
                                <strong>Creation Date:</strong>
                                <br />
                                <span t-field="o.date_start" />
                            </div>
                            <div class="col-2">
                                <strong>Source:</strong>
                                <br />
                                <span t-field="o.origin" />
                            </div>
                            <div class="col-2">
                                <strong>Requested by:</strong>
                                <br />
                                <span t-field="o.requested_by" />
                            </div>
                            <div class="col-2">
                                <strong>Assigned to:</strong>
                                <br />
                                <span t-field="o.assigned_to" />
                            </div>
                            <div class="col-2">
                                <strong>Project:</strong>
                                <br />
                                <span t-field="o.project_id" />
                            </div>
                        </div>
                        <div class="row mt32 mb32">
                            <div class="col-12">
                                <strong>Description:</strong>
                                <br />
                                <span t-field="o.description" />
                            </div>
                        </div>
                        <t t-if="o.line_ids">
                            <h3>Products</h3>
                            <table class="table table-condensed">
                                <thead>
                                    <tr>
                                        <th>
                                            <strong>Description</strong>
                                        </th>
                                        <th groups="analytic.group_analytic_accounting">
                                            <strong>Analytic Distribution</strong>
                                        </th>
                                        <th class="text-right">
                                            <strong>Qty</strong>
                                        </th>
                                        <th class="text-center" groups="uom.group_uom">
                                            <strong>Product UoM</strong>
                                        </th>
                                        <th class="text-right">
                                            <strong>Requested Date</strong>
                                        </th>
                                        <th>
                                            <strong>Technical Description</strong>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="o.line_ids" t-as="line_id">
                                        <td>
                                            <span t-field="line_id.name" />
                                        </td>
                                        <td groups="analytic.group_analytic_accounting">
                                            <t t-if="line_id.analytic_distribution">
                                                <t t-foreach="line_id.analytic_distribution.items()" t-as="dist">
                                                    <t t-set="account_ids" t-value="[int(x.strip()) for x in str(dist[0]).split(',') if x.strip().isdigit()]"/>
                                                    <t t-set="accounts" t-value="env['account.analytic.account'].browse(account_ids)"/>
                                                    <span t-esc="', '.join(accounts.mapped('name'))"/>
                                                    <span t-esc="' (' + str(dist[1]) + '%)'"/>
                                                    <br t-if="not dist_last"/>
                                                </t>
                                            </t>
                                        </td>
                                        <td class="text-right">
                                            <span t-field="line_id.product_qty" />
                                        </td>
                                        <t>
                                            <td
                                                class="text-center"
                                                groups="uom.group_uom"
                                            >
                                                <span
                                                    t-field="line_id.product_uom_id.category_id.name"
                                                />
                                            </td>
                                        </t>
                                        <td class="text-right">
                                            <span t-field="line_id.date_required" />
                                        </td>
                                        <td>
                                            <t t-out="line_id.technical_description"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </t>
                        <div id="oe_structure_report_request_2" class="oe_structure" />
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
