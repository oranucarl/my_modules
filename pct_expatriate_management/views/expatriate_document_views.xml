<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Document Form View -->
    <record id="view_expatriate_document_form" model="ir.ui.view">
        <field name="name">expatriate.document.form</field>
        <field name="model">expatriate.document</field>
        <field name="arch" type="xml">
            <form string="Expatriate Document">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Employee Info">
                            <field name="employee_id"/>
                            <field name="designation"/>
                            <field name="employment_status"/>
                        </group>
                        <group string="Document Info">
                            <field name="document_type"/>
                            <field name="sponsor_company_id"/>
                            <field name="document_number"/>
                            <field name="quota_status"/>
                        </group>
                    </group>
                    <group>
                        <group string="Passport">
                            <field name="passport_number"/>
                            <field name="passport_expiry"/>
                            <field name="passport_days_left"/>
                        </group>
                        <group string="Document Expiry">
                            <field name="expiry_date"/>
                            <field name="days_left"/>
                            <field name="alert_status" widget="badge"
                                   decoration-danger="alert_status in ('expired', 'urgent')"
                                   decoration-warning="alert_status == 'due_soon'"
                                   decoration-success="alert_status == 'safe'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Document List View -->
    <record id="view_expatriate_document_list" model="ir.ui.view">
        <field name="name">expatriate.document.list</field>
        <field name="model">expatriate.document</field>
        <field name="arch" type="xml">
            <list string="Expatriate Documents"
                  decoration-danger="alert_status in ('expired', 'urgent')"
                  decoration-warning="alert_status == 'due_soon'">
                <field name="employee_id"/>
                <field name="document_type"/>
                <field name="sponsor_company_id"/>
                <field name="designation"/>
                <field name="document_number"/>
                <field name="expiry_date"/>
                <field name="days_left"/>
                <field name="alert_status" widget="badge"
                       decoration-danger="alert_status in ('expired', 'urgent')"
                       decoration-warning="alert_status == 'due_soon'"
                       decoration-success="alert_status == 'safe'"/>
                <field name="employment_status"/>
            </list>
        </field>
    </record>

    <!-- Document Search View -->
    <record id="view_expatriate_document_search" model="ir.ui.view">
        <field name="name">expatriate.document.search</field>
        <field name="model">expatriate.document</field>
        <field name="arch" type="xml">
            <search string="Expatriate Documents">
                <field name="employee_id"/>
                <field name="document_type"/>
                <field name="sponsor_company_id"/>
                <filter string="Residence Permit" name="filter_residence" domain="[('document_type', '=', 'residence')]"/>
                <filter string="CERPEC" name="filter_cerpec" domain="[('document_type', '=', 'cerpec')]"/>
                <filter string="Work Permit" name="filter_work_permit" domain="[('document_type', '=', 'work_permit')]"/>
                <filter string="Visa" name="filter_visa" domain="[('document_type', '=', 'visa')]"/>
                <filter string="Other" name="filter_other" domain="[('document_type', '=', 'other')]"/>
                <separator/>
                <filter string="Expired" name="filter_expired" domain="[('alert_status', '=', 'expired')]"/>
                <filter string="Urgent" name="filter_urgent" domain="[('alert_status', '=', 'urgent')]"/>
                <filter string="Due Soon" name="filter_due_soon" domain="[('alert_status', '=', 'due_soon')]"/>
                <filter string="Safe" name="filter_safe" domain="[('alert_status', '=', 'safe')]"/>
                <separator/>
                <filter string="Active" name="filter_active" domain="[('employment_status', '=', 'active')]"/>
                <filter string="Left" name="filter_left" domain="[('employment_status', '=', 'left')]"/>
                <filter string="Not Renewed" name="filter_not_renewed" domain="[('employment_status', '=', 'not_renewed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Document Type" name="group_doc_type" context="{'group_by': 'document_type'}"/>
                    <filter string="Sponsor Company" name="group_sponsor" context="{'group_by': 'sponsor_company_id'}"/>
                    <filter string="Alert Status" name="group_alert" context="{'group_by': 'alert_status'}"/>
                    <filter string="Employment Status" name="group_employment" context="{'group_by': 'employment_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Document Action -->
    <record id="action_expatriate_document" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">expatriate.document</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
