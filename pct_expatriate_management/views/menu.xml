<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================================= -->
    <!-- ACTIONS FOR PAYROLL REPLICA MENUS        -->
    <!-- ========================================= -->

    <!-- Expatriate Employees Action -->
    <record id="action_expatriate_employees" model="ir.actions.act_window">
        <field name="name">Expatriate Employees</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">list,kanban,form,activity</field>
        <field name="domain">[('category_ids.is_expatriate', '=', True)]</field>
        <field name="context">{}</field>
    </record>

    <!-- Expatriate Contracts Action -->
    <record id="action_expatriate_contracts" model="ir.actions.act_window">
        <field name="name">Expatriate Contracts</field>
        <field name="res_model">hr.contract</field>
        <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
        <field name="domain">[('structure_type_id.is_expatriate', '=', True)]</field>
        <field name="context">{}</field>
    </record>

    <!-- Expatriate Payslip Batches Action -->
    <record id="action_expatriate_payslip_batches" model="ir.actions.act_window">
        <field name="name">Expatriate Payslip Batches</field>
        <field name="res_model">hr.payslip.run</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_expatriate', '=', True)]</field>
        <field name="context">{}</field>
    </record>

    <!-- Expatriate All Payslips Action -->
    <record id="action_expatriate_all_payslips" model="ir.actions.act_window">
        <field name="name">All Payslips</field>
        <field name="res_model">hr.payslip</field>
        <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
        <field name="domain">[('contract_id.structure_type_id.is_expatriate', '=', True)]</field>
        <field name="context">{}</field>
    </record>

    <!-- Employee Tags Action (filtered to expatriate tags) -->
    <record id="action_expatriate_employee_tags" model="ir.actions.act_window">
        <field name="name">Employee Tags</field>
        <field name="res_model">hr.employee.category</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_expatriate', '=', True)]</field>
    </record>

    <!-- ========================================= -->
    <!-- ROOT MENU: EXPATRIATE MANAGEMENT APP     -->
    <!-- ========================================= -->

    <menuitem id="menu_expatriate_root"
              name="Expatriate Management"
              sequence="100"
              web_icon="pct_expatriate_management,static/description/icon.png"
              groups="pct_payroll_expatriate.group_hr_payroll_expatriate"/>

    <!-- ========================================= -->
    <!-- EMPLOYEES MENU                            -->
    <!-- ========================================= -->

    <menuitem id="menu_expatriate_employees"
              name="Employees"
              parent="menu_expatriate_root"
              action="action_expatriate_employees"
              sequence="10"
              groups="pct_payroll_expatriate.group_hr_payroll_expatriate"/>

    <!-- ========================================= -->
    <!-- PAYROLL PARENT MENU                       -->
    <!-- ========================================= -->

    <menuitem id="menu_expatriate_payroll"
              name="Payroll"
              parent="menu_expatriate_root"
              sequence="20"
              groups="pct_payroll_expatriate.group_hr_payroll_expatriate"/>

    <!-- Payroll: Contracts -->
    <menuitem id="menu_expatriate_contracts"
              name="Contracts"
              parent="menu_expatriate_payroll"
              action="action_expatriate_contracts"
              sequence="10"
              groups="pct_payroll_expatriate.group_hr_payroll_expatriate"/>

    <!-- Payroll: Payslip Batches -->
    <menuitem id="menu_expatriate_payslip_batches"
              name="Payslip Batches"
              parent="menu_expatriate_payroll"
              action="action_expatriate_payslip_batches"
              sequence="20"
              groups="pct_payroll_expatriate.group_hr_payroll_expatriate"/>

    <!-- Payroll: All Payslips -->
    <menuitem id="menu_expatriate_all_payslips"
              name="All Payslips"
              parent="menu_expatriate_payroll"
              action="action_expatriate_all_payslips"
              sequence="30"
              groups="pct_payroll_expatriate.group_hr_payroll_expatriate"/>

    <!-- ========================================= -->
    <!-- ALLOWANCES MENU                           -->
    <!-- ========================================= -->

    <menuitem id="menu_expatriate_allowances"
              name="Allowances"
              parent="menu_expatriate_root"
              action="action_expatriate_allowance"
              sequence="30"
              groups="pct_payroll_expatriate.group_hr_payroll_expatriate"/>

    <!-- ========================================= -->
    <!-- HOUSING MENU                              -->
    <!-- ========================================= -->

    <menuitem id="menu_expatriate_housing"
              name="Housing"
              parent="menu_expatriate_root"
              action="action_expatriate_housing"
              sequence="40"
              groups="pct_payroll_expatriate.group_hr_payroll_expatriate"/>

    <!-- ========================================= -->
    <!-- DOCUMENTS MENU                            -->
    <!-- ========================================= -->

    <menuitem id="menu_expatriate_documents"
              name="Documents"
              parent="menu_expatriate_root"
              action="action_expatriate_document"
              sequence="50"
              groups="pct_payroll_expatriate.group_hr_payroll_expatriate"/>

    <!-- ========================================= -->
    <!-- CONFIGURATION PARENT MENU                 -->
    <!-- ========================================= -->

    <menuitem id="menu_expatriate_configuration"
              name="Configuration"
              parent="menu_expatriate_root"
              sequence="100"
              groups="pct_payroll_expatriate.group_hr_payroll_expatriate"/>

    <!-- Configuration: Employee Tags -->
    <menuitem id="menu_expatriate_employee_tags"
              name="Employee Tags"
              parent="menu_expatriate_configuration"
              action="action_expatriate_employee_tags"
              sequence="10"
              groups="pct_payroll_expatriate.group_hr_payroll_expatriate"/>

    <!-- Configuration: Sponsor Companies -->
    <menuitem id="menu_expatriate_sponsor_companies"
              name="Sponsor Companies"
              parent="menu_expatriate_configuration"
              action="action_expatriate_sponsor_company"
              sequence="20"
              groups="pct_payroll_expatriate.group_hr_payroll_expatriate"/>

</odoo>
