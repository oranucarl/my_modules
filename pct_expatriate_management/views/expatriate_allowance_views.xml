<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Allowance Form View -->
    <record id="view_expatriate_allowance_form" model="ir.ui.view">
        <field name="name">expatriate.allowance.form</field>
        <field name="model">expatriate.allowance</field>
        <field name="arch" type="xml">
            <form string="Expatriate Allowance">
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_pay" string="Mark as Paid" type="object"
                            class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="job_id"/>
                            <field name="department_id"/>
                            <field name="construction_site"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="amount" widget="monetary"/>
                            <field name="bank_name"/>
                            <field name="bank_account_number"/>
                            <field name="paid_from_account"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Allowance List View -->
    <record id="view_expatriate_allowance_list" model="ir.ui.view">
        <field name="name">expatriate.allowance.list</field>
        <field name="model">expatriate.allowance</field>
        <field name="arch" type="xml">
            <list string="Expatriate Allowances"
                  decoration-success="state == 'paid'"
                  decoration-info="state == 'confirmed'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="construction_site"/>
                <field name="date"/>
                <field name="amount"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'paid'"
                       decoration-info="state == 'confirmed'"/>
            </list>
        </field>
    </record>

    <!-- Allowance Search View -->
    <record id="view_expatriate_allowance_search" model="ir.ui.view">
        <field name="name">expatriate.allowance.search</field>
        <field name="model">expatriate.allowance</field>
        <field name="arch" type="xml">
            <search string="Expatriate Allowances">
                <field name="employee_id"/>
                <field name="construction_site"/>
                <field name="date"/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="filter_confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="Paid" name="filter_paid" domain="[('state', '=', 'paid')]"/>
                <group expand="0" string="Group By">
                    <filter string="Year" name="group_year" context="{'group_by': 'date:year'}"/>
                    <filter string="Month" name="group_month" context="{'group_by': 'date:month'}"/>
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Construction Site" name="group_site" context="{'group_by': 'construction_site'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Allowance Action with Default Group By -->
    <record id="action_expatriate_allowance" model="ir.actions.act_window">
        <field name="name">Allowances</field>
        <field name="res_model">expatriate.allowance</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'group_by': ['date:year', 'date:month']}</field>
    </record>

</odoo>
