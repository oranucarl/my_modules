<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Housing Export Wizard Form View -->
    <record id="view_housing_export_wizard_form" model="ir.ui.view">
        <field name="name">housing.export.wizard.form</field>
        <field name="model">housing.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Housing Report">
                <group invisible="excel_file">
                    <p class="text-muted">
                        Click "Generate Report" to export the selected housing records to Excel.
                    </p>
                    <field name="housing_ids" widget="many2many_tags" readonly="1"/>
                </group>
                <group invisible="not excel_file">
                    <p class="text-success">
                        Report generated successfully. Click the download link below.
                    </p>
                    <field name="excel_file" filename="filename" readonly="1"/>
                    <field name="filename" invisible="1"/>
                </group>
                <footer>
                    <button name="action_export" string="Generate Report" type="object" class="btn-primary" invisible="excel_file"/>
                    <button special="cancel" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
