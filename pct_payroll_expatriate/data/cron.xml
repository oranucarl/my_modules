<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Daily Cron: Recompute Expiry Dates for Housing -->
    <record id="ir_cron_recompute_expiry_dates" model="ir.cron">
        <field name="name">Expatriate: Recompute Expiry Dates</field>
        <field name="model_id" ref="model_expatriate_housing"/>
        <field name="state">code</field>
        <field name="code">model.cron_recompute_days()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <!-- Daily Cron: Send Contract Expiry Notifications -->
    <record id="ir_cron_contract_expiry_notifications" model="ir.cron">
        <field name="name">Expatriate: Send Contract Expiry Notifications</field>
        <field name="model_id" ref="hr_contract.model_hr_contract"/>
        <field name="state">code</field>
        <field name="code">model._send_expiry_notifications()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
