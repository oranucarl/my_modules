<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence for Expatriate Allowance -->
    <record id="seq_expatriate_allowance" model="ir.sequence">
        <field name="name">Expatriate Allowance</field>
        <field name="code">expatriate.allowance</field>
        <field name="prefix">EXP-ALW/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Pre-loaded Document Types -->
    <record id="document_type_residence_permit" model="expatriate.document.type">
        <field name="name">Residence Permit</field>
    </record>

    <record id="document_type_cerpec" model="expatriate.document.type">
        <field name="name">CERPEC</field>
    </record>

    <record id="document_type_work_permit" model="expatriate.document.type">
        <field name="name">Work Permit</field>
    </record>

    <record id="document_type_visa" model="expatriate.document.type">
        <field name="name">Visa</field>
    </record>

    <!-- Pre-loaded Sponsor Companies -->
    <record id="sponsor_alm_cd" model="expatriate.sponsor.company">
        <field name="name">ALM CD</field>
    </record>

    <record id="sponsor_alm_ss" model="expatriate.sponsor.company">
        <field name="name">ALM SS</field>
    </record>

    <record id="sponsor_amec" model="expatriate.sponsor.company">
        <field name="name">AMEC</field>
    </record>

    <record id="sponsor_schneider" model="expatriate.sponsor.company">
        <field name="name">SCHNEIDER</field>
    </record>

    <record id="sponsor_shahin" model="expatriate.sponsor.company">
        <field name="name">Shahin Construction</field>
    </record>

</odoo>
