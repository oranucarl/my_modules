<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Security Group for Expatriate Payroll Manager -->
    <record id="group_hr_payroll_expatriate" model="res.groups">
        <field name="name">Expatriate Payroll Manager</field>
        <field name="category_id" ref="base.module_category_usability"/>
        <field name="implied_ids" eval="[(4, ref('hr_payroll.group_hr_payroll_manager'))]"/>
        <field name="comment">Users with this access can view and manage expatriate payroll data including contracts, payslips, and batches.</field>
    </record>

    <!-- ======================= -->
    <!-- RECORD RULES            -->
    <!-- ======================= -->

    <!-- HR Contract - Non-Expatriate Rule (for regular payroll users) -->
    <record id="hr_contract_non_expatriate_rule" model="ir.rule">
        <field name="name">HR Contract: Non-Expatriate Only</field>
        <field name="model_id" ref="hr_contract.model_hr_contract"/>
        <field name="domain_force">[('structure_type_id.is_expatriate', '!=', True)]</field>
        <field name="groups" eval="[(4, ref('hr_payroll.group_hr_payroll_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- HR Contract - Expatriate Rule (for expatriate payroll managers) -->
    <record id="hr_contract_expatriate_rule" model="ir.rule">
        <field name="name">HR Contract: Expatriate Access</field>
        <field name="model_id" ref="hr_contract.model_hr_contract"/>
        <field name="domain_force">[('structure_type_id.is_expatriate', '=', True)]</field>
        <field name="groups" eval="[(4, ref('pct_payroll_expatriate.group_hr_payroll_expatriate'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

