<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Document Type Form View -->
    <record id="view_expatriate_document_type_form" model="ir.ui.view">
        <field name="name">expatriate.document.type.form</field>
        <field name="model">expatriate.document.type</field>
        <field name="arch" type="xml">
            <form string="Document Type">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Document Type List View -->
    <record id="view_expatriate_document_type_list" model="ir.ui.view">
        <field name="name">expatriate.document.type.list</field>
        <field name="model">expatriate.document.type</field>
        <field name="arch" type="xml">
            <list string="Document Types">
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Document Type Action -->
    <record id="action_expatriate_document_type" model="ir.actions.act_window">
        <field name="name">Document Types</field>
        <field name="res_model">expatriate.document.type</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
