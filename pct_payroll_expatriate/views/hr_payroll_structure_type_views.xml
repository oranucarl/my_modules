<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Structure Type Form to add is_expatriate field -->
    <record id="hr_payroll_structure_type_view_form_inherit" model="ir.ui.view">
        <field name="name">hr.payroll.structure.type.form.inherit.expatriate</field>
        <field name="model">hr.payroll.structure.type</field>
        <field name="inherit_id" ref="hr_payroll.hr_payroll_structure_type_view_form"/>
        <field name="arch" type="xml">
            <field name="wage_type" position="after">
                <field name="is_expatriate"/>
            </field>
        </field>
    </record>

    <!-- Inherit Structure Type List to add is_expatriate field -->
    <record id="hr_payroll_structure_type_view_list_inherit" model="ir.ui.view">
        <field name="name">hr.payroll.structure.type.list.inherit.expatriate</field>
        <field name="model">hr.payroll.structure.type</field>
        <field name="inherit_id" ref="hr_payroll.hr_payroll_structure_type_view_tree"/>
        <field name="arch" type="xml">
            <field name="country_id" position="after">
                <field name="is_expatriate"/>
            </field>
        </field>
    </record>
</odoo>
