<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Housing Form View -->
    <record id="view_expatriate_housing_form" model="ir.ui.view">
        <field name="name">expatriate.housing.form</field>
        <field name="model">expatriate.housing</field>
        <field name="arch" type="xml">
            <form string="Expatriate Housing">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_ids" widget="many2many_tags" domain="[('category_ids.is_expatriate', '=', True)]"/>
                            <field name="location"/>
                            <field name="housing_type"/>
                            <field name="total_cost" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="contract_start_date"/>
                            <field name="contract_end_date"/>
                            <field name="days_to_expire"/>
                            <field name="alert_status" widget="badge"
                                   decoration-danger="alert_status in ('expired', 'urgent')"
                                   decoration-warning="alert_status == 'due_soon'"
                                   decoration-success="alert_status == 'safe'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Cost Items">
                            <field name="cost_line_ids" context="{'default_housing_id': id}">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="employee_ids" widget="many2many_tags" string="Assigned To" domain="[('id', 'in', parent.employee_ids)]" optional="show"/>
                                    <field name="amount"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Employees">
                            <field name="employee_ids" widget="many2many" mode="list" domain="[('category_ids.is_expatriate', '=', True)]">
                                <list>
                                    <field name="name" string="Employee"/>
                                    <field name="job_id" string="Job Description"/>
                                    <field name="work_location_id" string="Site Location"/>
                                </list>
                            </field>
                        </page>
                        <page string="Available Assets">
                            <field name="available_assets"/>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Housing List View -->
    <record id="view_expatriate_housing_list" model="ir.ui.view">
        <field name="name">expatriate.housing.list</field>
        <field name="model">expatriate.housing</field>
        <field name="arch" type="xml">
            <list string="Expatriate Housing"
                  decoration-danger="alert_status in ('expired', 'urgent')"
                  decoration-warning="alert_status == 'due_soon'">
                <header>
                    <button name="action_export_housing_report" type="object" string="Export to Excel" icon="fa-file-excel-o"/>
                </header>
                <field name="employee_ids" widget="many2many_tags"/>
                <field name="employee_count" string="# Occupants" optional="hide"/>
                <field name="location"/>
                <field name="housing_type"/>
                <field name="contract_start_date" optional="hide"/>
                <field name="contract_end_date"/>
                <field name="days_to_expire"/>
                <field name="alert_status" widget="badge"
                       decoration-danger="alert_status in ('expired', 'urgent')"
                       decoration-warning="alert_status == 'due_soon'"
                       decoration-success="alert_status == 'safe'"/>
                <field name="total_cost"/>
            </list>
        </field>
    </record>

    <!-- Housing Search View -->
    <record id="view_expatriate_housing_search" model="ir.ui.view">
        <field name="name">expatriate.housing.search</field>
        <field name="model">expatriate.housing</field>
        <field name="arch" type="xml">
            <search string="Expatriate Housing">
                <field name="employee_ids"/>
                <field name="location"/>
                <!-- Expatriate/Non-Expatriate filters -->
                <filter string="Expatriate" name="filter_expatriate" domain="[('employee_ids.category_ids.is_expatriate', '=', True)]"/>
                <filter string="Non-Expatriate" name="filter_non_expatriate" domain="[('employee_ids.category_ids.is_expatriate', '!=', True)]"/>
                <separator/>
                <filter string="Expired" name="filter_expired" domain="[('alert_status', '=', 'expired')]"/>
                <filter string="Urgent" name="filter_urgent" domain="[('alert_status', '=', 'urgent')]"/>
                <filter string="Due Soon" name="filter_due_soon" domain="[('alert_status', '=', 'due_soon')]"/>
                <filter string="Safe" name="filter_safe" domain="[('alert_status', '=', 'safe')]"/>
                <group expand="0" string="Group By">
                    <filter string="Alert Status" name="group_alert" context="{'group_by': 'alert_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Housing Action for Expatriate Management (with default expatriate filter) -->
    <record id="action_expatriate_housing" model="ir.actions.act_window">
        <field name="name">Expatriate Housing</field>
        <field name="res_model">expatriate.housing</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_expatriate': 1}</field>
    </record>

    <!-- ================================================== -->
    <!-- FLEET HOUSING (General - All Employees)            -->
    <!-- ================================================== -->

    <!-- Inherited Form View for Fleet Housing - removes expatriate domain -->
    <record id="view_fleet_housing_form" model="ir.ui.view">
        <field name="name">expatriate.housing.form.fleet</field>
        <field name="model">expatriate.housing</field>
        <field name="inherit_id" ref="view_expatriate_housing_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <!-- Remove expatriate domain from tags widget -->
            <xpath expr="//field[@name='employee_ids'][@widget='many2many_tags']" position="attributes">
                <attribute name="domain">[]</attribute>
            </xpath>
            <!-- Remove expatriate domain from embedded list (widget=many2many) -->
            <xpath expr="//field[@name='employee_ids'][@widget='many2many']" position="attributes">
                <attribute name="domain">[]</attribute>
            </xpath>
        </field>
    </record>

    <!-- Housing Action for Fleet Module (all employees, no domain) -->
    <record id="action_fleet_housing" model="ir.actions.act_window">
        <field name="name">Housing</field>
        <field name="res_model">expatriate.housing</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_expatriate_housing_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_fleet_housing_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new housing record
            </p>
        </field>
    </record>

    <!-- Housing Menu under Fleet module (between Fleet and Reporting) -->
    <menuitem id="menu_fleet_housing"
              name="Housing"
              parent="fleet.menu_root"
              action="action_fleet_housing"
              groups="fleet.fleet_group_manager,fleet.fleet_group_user"
              sequence="50"/>

    <!-- Housing Reporting Action for Fleet (pivot/graph/list) -->
    <record id="action_fleet_housing_report" model="ir.actions.act_window">
        <field name="name">Housing Expiry Status</field>
        <field name="res_model">expatriate.housing</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="context">{'group_by': ['alert_status']}</field>
    </record>

    <!-- Housing Reporting under Fleet > Reporting -->
    <menuitem id="menu_fleet_housing_reporting"
              name="Housing"
              parent="fleet.menu_fleet_reporting"
              action="action_fleet_housing_report"
              groups="fleet.fleet_group_manager,fleet.fleet_group_user"
              sequence="10"/>

</odoo>
