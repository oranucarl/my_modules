<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Housing Form View -->
    <record id="view_expatriate_housing_form" model="ir.ui.view">
        <field name="name">expatriate.housing.form</field>
        <field name="model">expatriate.housing</field>
        <field name="arch" type="xml">
            <form string="Expatriate Housing">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="location"/>
                            <field name="housing_type"/>
                            <field name="renewal_date"/>
                        </group>
                        <group>
                            <field name="days_to_expire"/>
                            <field name="alert_status" widget="badge"
                                   decoration-danger="alert_status in ('expired', 'urgent')"
                                   decoration-warning="alert_status == 'due_soon'"
                                   decoration-success="alert_status == 'safe'"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="total_cost" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Cost Items">
                            <field name="cost_line_ids" context="{'default_housing_id': id}" mode="list"/>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Housing List View -->
    <record id="view_expatriate_housing_list" model="ir.ui.view">
        <field name="name">expatriate.housing.list</field>
        <field name="model">expatriate.housing</field>
        <field name="arch" type="xml">
            <list string="Expatriate Housing"
                  decoration-danger="alert_status in ('expired', 'urgent')"
                  decoration-warning="alert_status == 'due_soon'">
                <header>
                    <button name="action_export_housing_report" type="object" string="Export to Excel" icon="fa-file-excel-o"/>
                </header>
                <field name="employee_id"/>
                <field name="location"/>
                <field name="housing_type"/>
                <field name="renewal_date"/>
                <field name="days_to_expire"/>
                <field name="alert_status" widget="badge"
                       decoration-danger="alert_status in ('expired', 'urgent')"
                       decoration-warning="alert_status == 'due_soon'"
                       decoration-success="alert_status == 'safe'"/>
                <field name="total_cost"/>
            </list>
        </field>
    </record>

    <!-- Housing Search View -->
    <record id="view_expatriate_housing_search" model="ir.ui.view">
        <field name="name">expatriate.housing.search</field>
        <field name="model">expatriate.housing</field>
        <field name="arch" type="xml">
            <search string="Expatriate Housing">
                <field name="employee_id"/>
                <field name="location"/>
                <!-- Expatriate filter for employees who are expatriates -->
                <filter string="Expatriate" name="filter_expatriate" domain="[('employee_id.category_ids.is_expatriate', '=', True)]"/>
                <separator/>
                <filter string="Expired" name="filter_expired" domain="[('alert_status', '=', 'expired')]"/>
                <filter string="Urgent" name="filter_urgent" domain="[('alert_status', '=', 'urgent')]"/>
                <filter string="Due Soon" name="filter_due_soon" domain="[('alert_status', '=', 'due_soon')]"/>
                <filter string="Safe" name="filter_safe" domain="[('alert_status', '=', 'safe')]"/>
                <group expand="0" string="Group By">
                    <filter string="Alert Status" name="group_alert" context="{'group_by': 'alert_status'}"/>
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Housing Action for Expatriate Management (with default expatriate filter) -->
    <record id="action_expatriate_housing" model="ir.actions.act_window">
        <field name="name">Expatriate Housing</field>
        <field name="res_model">expatriate.housing</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_expatriate': 1}</field>
    </record>

    <!-- ================================================== -->
    <!-- FLEET HOUSING (General - All Employees)            -->
    <!-- ================================================== -->

    <!-- Inherited Form View for Fleet Housing - removes expatriate domain -->
    <record id="view_fleet_housing_form" model="ir.ui.view">
        <field name="name">expatriate.housing.form.fleet</field>
        <field name="model">expatriate.housing</field>
        <field name="inherit_id" ref="view_expatriate_housing_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <field name="employee_id" position="attributes">
                <attribute name="domain">[]</attribute>
            </field>
        </field>
    </record>

    <!-- Housing Action for Fleet Module (all employees, no domain) -->
    <record id="action_fleet_housing" model="ir.actions.act_window">
        <field name="name">Housing</field>
        <field name="res_model">expatriate.housing</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_expatriate_housing_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_fleet_housing_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new housing record
            </p>
        </field>
    </record>

    <!-- Housing Menu under Fleet module (between Fleet and Reporting) -->
    <menuitem id="menu_fleet_housing"
              name="Housing"
              parent="fleet.menu_root"
              action="action_fleet_housing"
              sequence="50"/>

</odoo>
