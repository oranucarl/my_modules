<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sponsor Company List View -->
    <record id="view_expatriate_sponsor_company_list" model="ir.ui.view">
        <field name="name">expatriate.sponsor.company.list</field>
        <field name="model">expatriate.sponsor.company</field>
        <field name="arch" type="xml">
            <list string="Sponsor Companies" editable="bottom">
                <field name="name"/>
                <field name="code"/>
            </list>
        </field>
    </record>

    <!-- Sponsor Company Form View -->
    <record id="view_expatriate_sponsor_company_form" model="ir.ui.view">
        <field name="name">expatriate.sponsor.company.form</field>
        <field name="model">expatriate.sponsor.company</field>
        <field name="arch" type="xml">
            <form string="Sponsor Company">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Sponsor Company Action -->
    <record id="action_expatriate_sponsor_company" model="ir.actions.act_window">
        <field name="name">Sponsor Companies</field>
        <field name="res_model">expatriate.sponsor.company</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
