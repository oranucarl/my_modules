<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Inherit account.payment form view to add destination_journal_id -->
    <record id="view_account_payment_form_transfer" model="ir.ui.view">
        <field name="name">account.payment.form.internal.transfer</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <!-- Add is_expense_payment field for view conditions -->
            <xpath expr="//field[@name='paired_internal_transfer_payment_id']" position="after">
                <field name="is_expense_payment" invisible="1"/>
            </xpath>

            <!-- Add destination journal field after the journal field -->
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="destination_journal_id"
                       invisible="payment_type != 'transfer'"
                       required="payment_type == 'transfer'"
                       options="{'no_create': True, 'no_open': True}"/>
            </xpath>

            <!-- Make partner_id (Customer - first occurrence) not required for internal transfers and expense payments -->
            <xpath expr="(//field[@name='partner_id'])[1]" position="attributes">
                <attribute name="required">payment_type != 'transfer' and not is_expense_payment</attribute>
                <attribute name="invisible">partner_type != 'customer' or payment_type == 'transfer'</attribute>
            </xpath>

            <!-- Make partner_id (Vendor - second occurrence) not required for internal transfers and expense payments -->
            <xpath expr="(//field[@name='partner_id'])[2]" position="attributes">
                <attribute name="required">payment_type != 'transfer' and not is_expense_payment</attribute>
                <attribute name="invisible">partner_type != 'supplier' or payment_type == 'transfer'</attribute>
            </xpath>

            <!-- Hide Customer Bank Account for internal transfers -->
            <xpath expr="(//field[@name='partner_bank_id'])[1]" position="attributes">
                <attribute name="invisible">not show_partner_bank_account or partner_type != 'customer' or payment_type == 'inbound' or payment_type == 'transfer'</attribute>
            </xpath>

            <!-- Hide Vendor Bank Account for internal transfers -->
            <xpath expr="(//field[@name='partner_bank_id'])[2]" position="attributes">
                <attribute name="invisible">not show_partner_bank_account or partner_type != 'supplier' or payment_type == 'inbound' or payment_type == 'transfer'</attribute>
            </xpath>

            <!-- Hide Company Bank Account for internal transfers -->
            <xpath expr="(//field[@name='partner_bank_id'])[3]" position="attributes">
                <attribute name="invisible">not show_partner_bank_account or payment_type == 'outbound' or payment_type == 'transfer'</attribute>
            </xpath>
        </field>
    </record>

    <!-- Also update the tree view to show transfer type properly -->
    <record id="view_account_payment_tree_transfer" model="ir.ui.view">
        <field name="name">account.payment.tree.internal.transfer</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_tree"/>
        <field name="arch" type="xml">
            <!-- Add destination journal column -->
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="destination_journal_id" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- Search view to filter by payment type -->
    <record id="view_account_payment_search_transfer" model="ir.ui.view">
        <field name="name">account.payment.search.internal.transfer</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='outbound_filter']" position="after">
                <filter name="transfer_filter" string="Internal Transfers"
                        domain="[('payment_type', '=', 'transfer')]"/>
            </xpath>
        </field>
    </record>
</odoo>
