<odoo>
    <record id="view_payment_form_project" model="ir.ui.view">
        <field name="name">account.payment.form.project</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="project_id"
                    required="1"
                    domain="[('account_id', '!=', False), '|', ('partner_id', '=', False), ('partner_id', '=', partner_id)]"/>
            </xpath>
        </field>
    </record>
</odoo>
