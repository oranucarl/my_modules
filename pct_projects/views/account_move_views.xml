<odoo>
    <record id="view_move_form_project" model="ir.ui.view">
        <field name="name">account.move.form.project</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="before">
                <!-- For invoices: filter projects by partner if set, or show all with analytic accounts -->
                <field name="project_id"
                    required="1"
                    domain="[('account_id', '!=', False), '|', ('partner_id', '=', False), ('partner_id', '=', partner_id)]"/>
                <!-- Project sequence number only visible on customer invoices (out_invoice), never on bills -->
                <field name="project_sequence_number" readonly="1" invisible="move_type != 'out_invoice' or not project_id"/>
            </xpath>
        </field>
    </record>
</odoo>
