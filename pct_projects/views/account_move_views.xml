<odoo>
    <!-- Inherit account.move form to add project_id and make analytic_distribution required -->
    <record id="view_move_form_project" model="ir.ui.view">
        <field name="name">account.move.form.project</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add project_id field -->
            <xpath expr="//field[@name='ref']" position="before">
                <field name="project_id" required="1"/>
                <!-- Project sequence number only visible on customer invoices (out_invoice), never on bills -->
                <field name="project_sequence_number" readonly="1" invisible="move_type != 'out_invoice' or not project_id"/>
            </xpath>

            <!-- Make analytic_distribution required in Invoice Lines tab -->
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='analytic_distribution']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>

            <!-- Make analytic_distribution required in Journal Items tab -->
            <xpath expr="//field[@name='line_ids']//list//field[@name='analytic_distribution']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
        </field>
    </record>

    <!-- Add project_id and project_sequence_number to customer invoice list view -->
    <record id="view_out_invoice_tree_project_sequence" model="ir.ui.view">
        <field name="name">account.move.tree.project.sequence</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="project_id" string="Project" optional="show"/>
                <field name="project_sequence_number" string="Project Seq. No." optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Add project_id to vendor bills list view -->
    <record id="view_in_invoice_bill_tree_project" model="ir.ui.view">
        <field name="name">account.move.bill.tree.project</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_in_invoice_bill_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="project_id" string="Project" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Add project_id to journal entries list view -->
    <record id="view_move_tree_project" model="ir.ui.view">
        <field name="name">account.move.tree.project</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="project_id" string="Project" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
