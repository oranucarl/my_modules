<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_state_of_origin" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.state.of.origin</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <field name="country_id" position="after">
                <field name="state_of_origin" options='{"no_open": True, "no_create": True}'/>
            </field>
        </field>
    </record>
</odoo>
