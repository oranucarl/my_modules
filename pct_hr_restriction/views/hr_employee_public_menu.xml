<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Action Domain Override for hr.employee.public
        ==============================================

        Override the public employee action to restrict base users to their own record.
        This uses a domain with context evaluation to check if user is HR or not.
    -->

    <!--
        Override the standard public employee action
        Restricts base users to see only their own employee record.
        HR users have their own action (hr.open_view_employee_list_my) with full access.
    -->
    <record id="hr.hr_employee_public_action" model="ir.actions.act_window">
        <field name="name">Employees</field>
        <field name="res_model">hr.employee.public</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('user_id', '=', uid)]</field>
        <field name="context">{'chat_icon': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Your employee profile
            </p>
            <p>
                View your employee information.
            </p>
        </field>
    </record>

    <!-- Window Action: My Employee Profile (for base users to view their own record) -->
    <record id="action_my_employee_profile" model="ir.actions.act_window">
        <field name="name">My Profile</field>
        <field name="res_model">hr.employee.public</field>
        <field name="view_mode">form</field>
        <field name="domain">[('user_id', '=', uid)]</field>
        <field name="context">{'form_view_initial_mode': 'edit'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Your employee profile
            </p>
            <p>
                View and update your basic employee information.
            </p>
        </field>
    </record>

</odoo>
